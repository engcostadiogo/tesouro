<body>

<h1>🧭 Caça ao Tesouro</h1>

<div class="card">
  <div id="arrow">⬆️</div>
  <p class="big" id="instrucao">--</p>
</div>

<div class="card">
  <p>Heading: <span id="heading">--</span>°</p>
  <p>Bearing: <span id="bearing">--</span>°</p>
  <p>Distância: <span id="distance">--</span> m</p>
</div>

<div class="card">
  <div>Lat: <span id="lat">--</span></div>
  <div>Lon: <span id="lon">--</span></div>
  <div>Alt: <span id="alt">--</span></div>
</div>

<button onclick="pedirPermissao()">Ativar sensores</button>
<button onclick="downloadTrack()">Baixar trajeto</button>

<script>

let waypoints = [
  {lat: -15.793889, lon: -47.882778},
  {lat: -15.794500, lon: -47.881200},
  {lat: -15.795200, lon: -47.880000}
];

let currentWP = 0;
let heading = 0;
let track = [];

function pedirPermissao(){
  if (typeof DeviceOrientationEvent.requestPermission === 'function') {
    DeviceOrientationEvent.requestPermission()
      .then(response => {
        if (response === 'granted') {
          iniciar();
        }
      })
      .catch(console.error);
  } else {
    iniciar();
  }
}

function iniciar(){

  window.addEventListener("deviceorientationabsolute", (event) => {
    if (event.alpha !== null) {
      heading = 360 - event.alpha;
      document.getElementById("heading").innerText = heading.toFixed(1);
    }
  });

  navigator.geolocation.watchPosition(pos => {

    let lat = pos.coords.latitude;
    let lon = pos.coords.longitude;

    document.getElementById("lat").innerText = lat.toFixed(6);
    document.getElementById("lon").innerText = lon.toFixed(6);
    document.getElementById("alt").innerText = pos.coords.altitude?.toFixed(1) ?? "N/A";

    let target = waypoints[currentWP];

    let d = distance(lat, lon, target.lat, target.lon);
    let b = bearing(lat, lon, target.lat, target.lon);

    document.getElementById("distance").innerText = d.toFixed(1);
    document.getElementById("bearing").innerText = b.toFixed(1);

    let err = headingError(heading, b);

    let instrucao = "";

    if (Math.abs(err) < 5) {
      instrucao = "Siga em frente";
    } else if (err > 0) {
      instrucao = "Vire " + err.toFixed(0) + "° à direita";
    } else {
      instrucao = "Vire " + Math.abs(err).toFixed(0) + "° à esquerda";
    }

    document.getElementById("instrucao").innerText = instrucao;

    document.getElementById("arrow").style.transform = `rotate(${err}deg)`;

    track.push({lat, lon, t: Date.now()});

    if (d < 10) {
      alert("Waypoint " + (currentWP+1) + " alcançado!");
      currentWP++;
      if (currentWP >= waypoints.length) {
        alert("Parabéns! Tesouro encontrado!");
        currentWP = waypoints.length - 1;
      }
    }

  }, err => console.log(err), { enableHighAccuracy: true });
}

function toRad(deg){ return deg * Math.PI / 180; }
function toDeg(rad){ return rad * 180 / Math.PI; }

function distance(lat1, lon1, lat2, lon2){
  let R = 6371000;
  let dLat = toRad(lat2-lat1);
  let dLon = toRad(lon2-lon1);

  let a = Math.sin(dLat/2)**2 +
          Math.cos(toRad(lat1)) *
          Math.cos(toRad(lat2)) *
          Math.sin(dLon/2)**2;

  let c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1-a));
  return R * c;
}

function bearing(lat1, lon1, lat2, lon2){
  let dLon = toRad(lon2 - lon1);

  let y = Math.sin(dLon) * Math.cos(toRad(lat2));
  let x = Math.cos(toRad(lat1))*Math.sin(toRad(lat2)) -
          Math.sin(toRad(lat1))*Math.cos(toRad(lat2))*Math.cos(dLon);

  let brng = toDeg(Math.atan2(y, x));
  return (brng + 360) % 360;
}

function headingError(current, target){
  let diff = target - current;

  if (diff > 180) diff -= 360;
  if (diff < -180) diff += 360;

  return diff;
}

function downloadTrack(){
  let data = JSON.stringify(track, null, 2);
  let blob = new Blob([data], {type: "application/json"});
  let url = URL.createObjectURL(blob);

  let a = document.createElement("a");
  a.href = url;
  a.download = "trajeto.json";
  a.click();
}

</script>

